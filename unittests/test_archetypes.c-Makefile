# Makefile for test_archetypes.c
# LuminariMUD archetype core (MVP) unit tests

CC = gcc
CFLAGS = -g -Wall -I../src -I../.. -DTEST_BUILD
LDFLAGS =
LIBS =

# Source files
TEST_SRCS = test_archetypes.c CuTest/CuTest.c

# Object files
TEST_OBJS = $(TEST_SRCS:.c=.o)

# Target executable
TARGET = test_archetypes

# Default target
all: $(TARGET)

# Link the test executable (archetypes.c compiled separately to keep flags)
$(TARGET): $(TEST_OBJS) archetypes_test.o
	$(CC) $(LDFLAGS) -o $@ $^ $(LIBS)

# Special rule for archetypes.c
archetypes_test.o: ../src/archetypes.c
	$(CC) $(CFLAGS) -DTEST_BUILD -c -o $@ $<

# Compile test files
%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# Clean up
clean:
	rm -f $(TEST_OBJS) archetypes_test.o $(TARGET)

# Run the tests
test: $(TARGET)
	./$(TARGET)

.PHONY: all clean test
